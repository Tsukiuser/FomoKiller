<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keywordsPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:elevation="16dp"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_keywords_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_keywords_desc"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <!-- Sélecteur de mode à configurer (Activé / Protégé) -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroupKeywordMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:checkedButton="@+id/btnConfigKillAll"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfigKillAll"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_kill_all" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfigVipOnly"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mode_vip_only" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Sélecteur de type d'action (Autoriser / Bloquer) -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroupKeywordAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:checkedButton="@+id/btnActionAllow"
            app:selectionRequired="true"
            app:singleSelection="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionAllow"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/keyword_action_allow" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionBlock"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/keyword_action_block" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputKeywordLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/keyword_input_hint"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_input_add">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editKeyword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/keywordChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:chipSpacing="8dp" />

    </LinearLayout>

    <!-- Poignée en bas (Inversé) -->
    <LinearLayout
        android:id="@+id/keywordsHandle"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:alpha="0.5">
        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:background="#40808080"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</LinearLayout>
